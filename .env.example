# Crafted CV — Environment Variables
# Copy this file to `.env` for local development, and set the same
# variables in your Vercel project (Settings → Environment Variables).
# All client-exposed vars MUST be prefixed with VITE_.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon / publishable key (safe to expose to the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project ref id (optional, e.g. xxxxxxxx)
VITE_SUPABASE_PROJECT_ID=
